*.log
*.tmp
*.swp
*.swo
*.bak
*.~
*~

# OS generated files
.DS_Store
Thumbs.db
ehthumbs.db
Icon?
.directory
*.nib
.vagrant/
.svn/

# IDE specific
.vscode/
.idea/
*.iml
*.ipr
*.iws
.settings/
.project
.classpath
.pydevproject

# Coverage reports
coverage/
htmlcov/
.coverage
*.cover
coverage.xml
*.gcda
*.gcno

# Python specific
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.tox/
.hypothesis/

# Node.js specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*
node_modules/
jspm_packages/
*.tsbuildinfo
.nyc_output/

# Java specific
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# C/C++ specific
*.o
*.a
*.so
*.dll
*.dylib
*.exe
*.out
*.obj

# Go specific
*.exe
*.exe~
*.dll
*.so
*.dylib

# Ruby specific
*.gem
*.rbc
.bundle/
.config/yardoc
.yardoc/
_vendor/

# Rust specific
target/
Cargo.lock

# Gradle specific
.gradle/
build/

# Maven specific
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties

# Web specific
.sass-cache/
connect.lock
.yarn-integrity
.yarn-metadata.json
node_modules/
jspm_packages/
*.wasm

# Compression
*.zip
*.tar.gz
*.tgz
*.tar
*.gz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
